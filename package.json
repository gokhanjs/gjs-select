{
  "name": "gjs-select",
  "version": "1.0.2",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "A feature-complete, accessible Select for React and shadcn/ui — single, multiple, and tags modes, built-in search, virtualized lists, and antd-grade behavior. Install by copy-paste with the shadcn CLI.",
  "license": "MIT",
  "author": "gokhanjs",
  "homepage": "https://gjs-select.gokhanyildiz.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokhanjs/gjs-select.git"
  },
  "bugs": {
    "url": "https://github.com/gokhanjs/gjs-select/issues"
  },
  "keywords": [
    "react",
    "select",
    "shadcn",
    "shadcn-ui",
    "combobox",
    "multi-select",
    "tags-input",
    "accessible",
    "virtualized",
    "tailwindcss",
    "radix-ui"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "shadcn build && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --project=functional",
    "test:a11y": "playwright test --project=a11y",
    "test:perf": "playwright test --project=perf",
    "test:stress": "playwright test --project=stress",
    "test:patterns": "playwright test --project=patterns",
    "test:visual": "playwright test --project=visual",
    "test:all": "playwright test",
    "test:update-snapshots": "playwright test --project=visual --update-snapshots"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
